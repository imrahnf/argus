[
  { "name": "tx_id", "type": "STRING", "mode": "REQUIRED", "description": "Globally unique transaction identifier" },
  { "name": "card_id", "type": "STRING", "mode": "REQUIRED", "description": "Masked card identifier" },
  { "name": "amount", "type": "NUMERIC", "mode": "REQUIRED", "description": "Transaction amount in the given currency" },
